generator client {
  provider = "prisma-client"
  output   = "./generated/client"
}

datasource db {
  provider = "postgresql"
}

/// 👤 Users
model User {
  id        String   @id @default(uuid()) @db.Uuid
  clerkId   String?  @unique @map("clerk_id")
  name      String
  email     String?  @unique
  timezone  String?
  createdAt DateTime @default(now()) @map("created_at")

  memories Memory[]
  messages Message[]

  @@map("users")
}

/// 🧠 Memories
model Memory {
  id      String     @id @default(uuid()) @db.Uuid
  userId  String     @map("user_id") @db.Uuid // foreign key.
  type    MemoryType @map("type")
  content String     @db.Text

  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id]) //Prisma relationship helper.

  @@index([userId])
  @@index([type])
  @@map("memories")
}

enum MemoryType {
  short_term
  medium_term
  long_term
  episodic
}

/// 💬 Messages
model Message {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid //foreign key.
  platform  String?
  role      Role     @map("role")
  content   String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id]) // Prisma relationship helper. 

  @@index([userId])
  @@index([createdAt])
  @@map("messages")
}

enum Role {
  user
  assistant
  system
}
